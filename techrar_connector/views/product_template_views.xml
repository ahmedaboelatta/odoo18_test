<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_techrar" model="ir.ui.view">
        <field name="name">product.template.form.inherit.techrar</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="inside">
                <group string="Techrar" name="techrar_group" colspan="2">
                    <field name="is_techrar_subscription"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_techrar_product_tree" model="ir.ui.view">
        <field name="name">product.template.tree.techrar</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Techrar Subscription Products">
                <field name="name"/>
                <field name="default_code"/>
                <field name="list_price"/>
                <field name="is_techrar_subscription"/>
            </list>
        </field>
    </record>

    <record id="view_techrar_product_form" model="ir.ui.view">
        <field name="name">product.template.form.techrar</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form string="Techrar Subscription Product">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="default_code"/>
                        <field name="list_price"/>
                        <field name="is_techrar_subscription"/>
                        <field name="type"/>
                        <field name="sale_ok"/>
                        <field name="purchase_ok"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_techrar_product_kanban" model="ir.ui.view">
        <field name="name">product.template.kanban.techrar</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban string="Techrar Subscription Products" create="false">
                <field name="name"/>
                <field name="default_code"/>
                <field name="list_price"/>
                <field name="is_techrar_subscription"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <field name="name"/>
                            <field name="default_code"/>
                            <field name="list_price"/>
                            <field name="is_techrar_subscription"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_techrar_product" model="ir.actions.act_window">
        <field name="name">Techrar Subscription Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_techrar_subscription', '=', True)]</field>
    </record>
</odoo>
