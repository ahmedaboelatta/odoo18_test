<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_techrar_branch_list" model="ir.ui.view">
        <field name="name">techrar.branch.list</field>
        <field name="model">techrar.branch</field>
        <field name="arch" type="xml">
            <list string="Techrar Branches">
                <field name="name"/>
                <field name="techrar_branch_id"/>
                <field name="warehouse_id"/>
                <field name="analytic_account_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_techrar_branch_form" model="ir.ui.view">
        <field name="name">techrar.branch.form</field>
        <field name="model">techrar.branch</field>
        <field name="arch" type="xml">
            <form string="Techrar Branch">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="techrar_branch_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Mapping">
                        <field name="warehouse_id"/>
                        <field name="analytic_account_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
