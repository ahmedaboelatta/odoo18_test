<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_techrar_branch_list" model="ir.ui.view">
        <field name="name">techrar.branch.list</field>
        <field name="model">techrar.branch</field>
        <field name="arch" type="xml">
            <list string="Techrar Branches">
                <field name="name"/>
                <field name="branch_name_en"/>
                <field name="techrar_branch_id"/>
                <field name="city_name_en"/>
                <field name="warehouse_id"/>
                <field name="analytic_account_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_techrar_branch_form" model="ir.ui.view">
        <field name="name">techrar.branch.form</field>
        <field name="model">techrar.branch</field>
        <field name="arch" type="xml">
            <form string="Techrar Branch">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="branch_name_en"/>
                        <field name="techrar_branch_id"/>
                        <field name="city_name_en"/>
                        <field name="active"/>
                    </group>
                    <group string="Mapping">
                        <field name="warehouse_id"/>
                        <field name="analytic_account_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_techrar_branch" model="ir.actions.act_window">
        <field name="name">Techrar Branches</field>
        <field name="res_model">techrar.branch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Techrar Branch!
            </p>
        </field>
    </record>
</odoo>
