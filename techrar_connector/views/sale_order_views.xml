<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_inherit_techrar" model="ir.ui.view">
        <field name="name">sale.order.inherit.techrar</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Techrar Information" name="techrar_info_group" invisible="not techrar_order_id">
                    <field name="techrar_order_id" readonly="1"/>
                    <field name="techrar_subscription_id" readonly="1"/>
                    <field name="techrar_branch_id" readonly="1"/>
                    <field name="techrar_delivery_type" readonly="1"/>
                    <field name="techrar_delivery_address" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_tree_techrar" model="ir.ui.view">
        <field name="name">sale.order.tree.techrar</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="techrar_order_id"/>
            </xpath>
            <xpath expr="//field[@name='amount_total']" position="before">
                <field name="techrar_delivery_type"/>
            </xpath>
        </field>
    </record>
</odoo>
