<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_techrar_config" model="ir.actions.act_window">
        <field name="name">Techrar Configuration</field>
        <field name="res_model">techrar.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_main_techrar"
        name="Techrar Connector"
        sequence="10"
        web_icon="techrar_connector,static/description/logo.png"
    >
        <menuitem
            id="techrar_branch_menu"
            name="Branches"
            sequence="10"
        >
            <menuitem
                id="techrar_branch_list_menu"
                name="All Branches"
                sequence="10"
                action="techrar_connector.action_techrar_branch"
            />
        </menuitem>
        <menuitem
            id="techrar_sync_menu"
            name="Sync Orders"
            sequence="20"
            action="techrar_connector.action_techrar_sync_wizard"
        />
        <menuitem
            id="techrar_sale_order_menu"
            name="Orders"
            sequence="30"
            action="techrar_connector.action_sale_order_techrar"
        />
        <menuitem
            id="menu_techrar_config_settings"
            name="Configuration"
            sequence="100"
            action="techrar_connector.action_techrar_config"
        />
    </menuitem>
</odoo>
