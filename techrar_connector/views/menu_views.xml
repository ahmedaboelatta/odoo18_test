<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="techrar_connector_menu" model="ir.ui.menu">
        <field name="name">Techrar Connector</field>
        <field name="sequence">10</field>
    </record>

    <!-- Branches -->
    <record id="action_techrar_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">techrar.branch</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="techrar_branch_menu" model="ir.ui.menu">
        <field name="name">Branches</field>
        <field name="parent_id" ref="techrar_connector_menu"/>
        <field name="sequence">10</field>
        <field name="action" ref="techrar_connector.action_techrar_branch"/>
    </record>

    <!-- Manual Sync -->
    <record id="action_techrar_sync_wizard" model="ir.actions.act_window">
        <field name="name">Sync Orders</field>
        <field name="res_model">techrar.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="techrar_connector.view_techrar_sync_wizard_form"/>
    </record>
    <record id="techrar_sync_menu" model="ir.ui.menu">
        <field name="name">Sync Orders</field>
        <field name="parent_id" ref="techrar_connector_menu"/>
        <field name="sequence">20</field>
        <field name="action" ref="techrar_connector.action_techrar_sync_wizard"/>
    </record>

    <!-- Sale Orders -->
    <record id="action_sale_order_techrar" model="ir.actions.act_window">
        <field name="name">Techrar Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('techrar_order_id', '!=', False)]</field>
        <field name="context">{ 'search_default_group_by_state': 1 }</field>
    </record>
    <record id="techrar_sale_order_menu" model="ir.ui.menu">
        <field name="name">Orders</field>
        <field name="parent_id" ref="techrar_connector_menu"/>
        <field name="sequence">30</field>
        <field name="action" ref="techrar_connector.action_sale_order_techrar"/>
    </record>
</odoo>
