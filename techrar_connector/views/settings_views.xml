<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_form_techrar" model="ir.ui.view">
        <field name="name">res.config.settings.form.techrar</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <form string="Configuration">
                <settings>
                    <div class="mt16 o_settings_container">
                        <h2 class="mt16">Techrar API</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <field name="techrar_api_base_url"/>
                                    <div class="text-muted">
                                        Base URL for the Techrar API (e.g., https://api.techrar.com)
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <field name="techrar_api_token"/>
                                    <div class="text-muted">
                                        Bearer token for authenticating with the Techrar API.
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <field name="techrar_app_id"/>
                                    <div class="text-muted">
                                        App ID associated with the Techrar account.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </settings>
            </form>
        </field>
    </record>
</odoo>
