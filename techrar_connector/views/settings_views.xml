<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_techrar" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.techrar</field>
        <field name="model">res.config.settings</field>
        <field name="priority">10</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Techrar Connector" name="techrar_connector">
                    <block title="Techrar API Configuration" id="techrar_api_config">
                        <setting string="API Credentials" help="Configure Techrar API Token and App ID">
                            <div class="o_settings_grid">
                                    <div class="w-100">
                                        <div class="row mt16">
                                            <label for="techrar_api_token" class="col-lg-3 o_light_label"/>
                                            <div class="col-lg-9">
                                                <field name="techrar_api_token" password="True" class="w-100"/>
                                            </div>
                                        </div>
                                        <div class="row mt16">
                                            <label for="techrar_app_id" class="col-lg-3 o_light_label"/>
                                            <div class="col-lg-9">
                                                <field name="techrar_app_id" class="w-100"/>
                                            </div>
                                        </div>
                                        <div class="row mt16">
                                            <label for="techrar_api_url" class="col-lg-3 o_light_label"/>
                                            <div class="col-lg-9">
                                                <field name="techrar_api_url" class="w-100"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_techrar_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'techrar_connector', 'bin_size': False}</field>
    </record>
</odoo>
