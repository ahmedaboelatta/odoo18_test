<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="module_techrar_connector_category" model="ir.module.category">
        <field name="name">Techrar Connector</field>
        <field name="sequence">10</field>
    </record>
    <record id="module_techrar_connector_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_techrar_connector_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="module_techrar_connector_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_techrar_connector_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
