                                            </td>
                                            <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                                <t t-esc="line.salary_rule_id.name"/>
                                            </td>
                                            <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                                <t t-esc="counter"/> <!-- Display the counter -->
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </t>

                            <!-- Loop through Allowances -->
