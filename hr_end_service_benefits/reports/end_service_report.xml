                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="allowance.other_allowances"/>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="allowance.other_allowances_note"/>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="counter"/>
                                    </td>
                                </tr>
                            </t>

                            <!-- Loop through Deductions -->
                            <t t-foreach="doc.deduct_ids" t-as="deduction">
                                <t t-set="total_deduction" t-value="total_deduction + deduction.detuction"/>
                                <t t-set="counter" t-value="counter + 1"/>
                                <tr>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">

                                        <t t-esc="deduction.type_detuction.name"/>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="deduction.detuction"/>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="deduction.detuction_note"/>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="counter"/>
                                    </td>
                                </tr>
                            </t>
                            <tr t-if="doc.deduction_loan > 0" >
                                <t t-set="counter" t-value="counter + 1"/>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <span>Deduction Loan</span>
                                </td>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <span t-esc="'{0:,.3f}'.format(doc.deduction_loan)"/>
                                </td>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <span></span>
                                </td>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <t t-esc="counter"/>
                                </td>
                            </tr>
                            <tr t-if="doc.last_month_worked > 0">
                                <t t-set="counter" t-value="counter + 1"/>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <span>Last Month Worked Days Amount</span>
                                </td>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <span t-esc="'{0:,.3f}'.format(doc.last_month_worked)"/>
                                </td>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <span></span>
                                </td>
                                <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                    <t t-esc="counter"/>
                                </td>
                            </tr>

                            <!-- Final Total Row -->

                            <tr>
                                <td
                                        style="background-color: #d9d9d9; border: 1px solid black;padding:4px;">
                                    TOTAL AMOUNT DUE
                                </td>
                                <td colspan="2" style="border: 1px solid black; font-weight: bold;padding:4px;">
                                    <t t-esc="'{0:,.3f}'.format(doc.amount)"/>
                                </td>
                                <td colspan="2" style="border: 1px solid black;padding:4px;background-color: #d9d9d9;">
                                    المبلغ الصافي المستحق
                                </td>
                            </tr>
