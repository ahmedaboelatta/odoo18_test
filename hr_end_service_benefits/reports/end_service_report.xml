                                        </t>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="counter"/>
                                    </td>
                                </tr>
                            </t>

                            <!-- Loop through Payroll -->
                            <t t-foreach="doc.payslip_ids" t-as="payslip">
                                <t t-foreach="payslip.line_ids" t-as="line">
                                    <t t-if="line.salary_rule_id.code == 'NET'">
                                        <t t-set="total_deduction" t-value="total_deduction + line.total"/>
                                        <t t-set="counter" t-value="counter + 1"/>
