                            <t t-set="counter" t-value="0"/>
                            <t t-set="total_allowance" t-value="0"/>
                            <t t-set="total_deduction" t-value="0"/>


                            <!-- loop through holiday -->
                            <t t-foreach="doc.holiday_line_ids" t-as="holiday">
                                <t t-set="counter" t-value="counter + 1"/>

                                <tr>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
                                        <t t-esc="holiday.holiday_id.name"/>
                                    </td>
                                    <td style="border: 1px solid black; height: 5px; text-align: center;padding:4px;">
