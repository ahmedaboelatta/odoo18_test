                            <!--                                <td-->
                            <!--                                        style="background-color: #d9d9d9; border: 1px solid black;padding:10px;">-->
                            <!--                                    NET AMOUNT PAYABLE-->
                            <!--                                </td>-->
                            <!--                                <td colspan="2" style="border: 1px solid black; font-weight: bold;padding:10px;">-->
                            <!--                                    &lt;!&ndash;                                    <t t-esc="'{0:,.3f}'.format(total_allowance + total_deduction + doc.amount_due)"/>&ndash;&gt;-->
                            <!--                                </td>-->
