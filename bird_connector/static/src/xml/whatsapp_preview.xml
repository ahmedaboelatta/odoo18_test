<templates xml:space="preserve">
    <t t-name="bird_connector.WhatsappPreviewPanel">
        <div class="o_bird_whatsapp_preview panel panel-default mb-0">
            <div class="panel-heading">
                <h4 class="panel-title">WhatsApp Preview</h4>
            </div>
            <div class="panel-body">
                <div class="o_whatsapp_phone_frame">
                    <div class="o_whatsapp_screen">
                        <div class="o_whatsapp_chat_header bg-primary text-white p-2">
                            <span class="o_whatsapp_back_arrow mr-2">&#8592;</span>
                            <span class="o_whatsapp_contact_name">Business</span>
                        </div>
                        <div class="o_whatsapp_messages_area p-3">
                            <div class="o_whatsapp_message_bubble bg-white p-2 shadow-sm">
                                <t t-if="state.headerImage">
                                    <img t-att-src="state.headerImage" class="img-fluid mb-2 rounded" style="max-height:180px; object-fit:cover;" />
                                </t>
                                <t t-if="state.bodyText">
                                    <div class="o_whatsapp_body_text mb-2" style="white-space: pre-wrap; word-wrap: break-word;" t-raw="state.bodyText"></div>
                                </t>
                                <t t-if="state.footerText">
                                    <div class="o_whatsapp_footer_text text-muted small mt-1 pt-1 border-top" t-raw="state.footerText"></div>
                                </t>
                                <t t-if="state.buttonUrl">
                                    <a t-att-href="state.buttonUrl" target="_blank" class="o_whatsapp_url_button btn btn-success btn-sm mt-2 w-100">
                                        <t t-esc="state.buttonText"/>
                                        <span class="ml-1">&#x2197;</span>
                                    </a>
                                </t>
                            </div>
                        </div>
                        <div class="o_whatsapp_chat_input_area p-2 bg-light border-top">
                            <div class="input-group">
                                <span class="input-group-addon">&#128512;</span>
                                <input type="text" class="form-control" placeholder="Type a message" readonly />
                                <span class="input-group-addon">&#127911;</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
