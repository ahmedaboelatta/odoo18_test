<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bird_message_tree" model="ir.ui.view">
        <field name="name">bird.message.tree</field>
        <field name="model">bird.message</field>
        <field name="arch" type="xml">
            <list string="Messages" decoration-success="status=='delivered' or status=='read'" decoration-danger="status=='failed'">
                <field name="organization_id"/>
                <field name="message_id"/>
                <field name="direction"/>
                <field name="status" decoration-success="status=='delivered' or status=='read'" decoration-primary="status=='sent'" decoration-warning="status=='pending'" decoration-danger="status=='failed'"/>
                <field name="body"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
    <record id="view_bird_message_form" model="ir.ui.view">
        <field name="name">bird.message.form</field>
        <field name="model">bird.message</field>
        <field name="arch" type="xml">
            <form string="Message">
                <sheet>
                    <group col="4">
                        <field name="organization_id"/>
                        <field name="channel_id"/>
                        <field name="contact_id"/>
                        <field name="conversation_id"/>
                        <field name="message_id"/>
                        <field name="direction"/>
                        <field name="status"/>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="body" nolabel="1"/>
                        </page>
                        <page string="Payload &amp; Response" name="payload">
                            <field name="payload" nolabel="1"/>
                            <field name="response" nolabel="1" class="mt16"/>
                            <field name="error_message" nolabel="1" class="mt16"/>
                        </page>
                        <page string="Timestamps" name="timestamps">
                            <group col="4">
                                <field name="sent_at"/>
                                <field name="delivered_at"/>
                                <field name="read_at"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
