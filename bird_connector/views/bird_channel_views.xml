<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bird_channel_tree" model="ir.ui.view">
            <field name="name">bird.channel.tree</field>
            <field name="model">bird.channel</field>
            <field name="arch" type="xml">
                <tree string="Bird Channels">
                    <field name="name"/>
                    <field name="channel_type"/>
                    <field name="connected_account"/>
                    <field name="workspace_id"/>
                    <field name="state" decoration-info="state=='disconnected'"/>
                </tree>
            </field>
        </record>

        <record id="view_bird_channel_search" model="ir.ui.view">
            <field name="name">bird.channel.search</field>
            <field name="model">bird.channel</field>
            <field name="arch" type="xml">
                <search string="Search Bird Channels">
                    <field name="name"/>
                    <field name="channel_type"/>
                    <field name="connected_account"/>
                    <field name="workspace_id"/>
                </search>
            </field>
        </record>

        <record id="view_bird_channel_form" model="ir.ui.view">
            <field name="name">bird.channel.form</field>
            <field name="model">bird.channel</field>
            <field name="arch" type="xml">
                <form string="Bird Channel">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <div>
                                <h1><field name="name" placeholder="Channel Name"/></h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="channel_type"/>
                                <field name="channel_id"/>
                            </group>
                            <group>
                                <field name="connected_account"/>
                                <field name="workspace_id"/>
                                <field name="state"/>
                                <field name="last_activity"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_bird_channel_kanban" model="ir.ui.view">
            <field name="name">bird.channel.kanban</field>
            <field name="model">bird.channel</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="name"/>
                    <field name="channel_type"/>
                    <field name="state"/>
                    <field name="connected_account"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_card">
                                    <div class="oe_kanban_content">
                                        <field name="name"/>
                                        <div><field name="channel_type"/></div>
                                        <div><field name="connected_account"/></div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>
