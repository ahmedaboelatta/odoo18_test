<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bird_device_token_tree" model="ir.ui.view">
        <field name="name">bird.device.token.tree</field>
        <field name="model">bird.device.token</field>
        <field name="arch" type="xml">
            <tree string="Device Tokens">
                <field name="name"/>
                <field name="organization_id"/>
                <field name="partner_id"/>
                <field name="platform"/>
                <field name="device_id"/>
                <field name="active"/>
                <field name="last_used"/>
            </tree>
        </field>
    </record>
    <record id="view_bird_device_token_form" model="ir.ui.view">
        <field name="name">bird.device.token.form</field>
        <field name="model">bird.device.token</field>
        <field name="arch" type="xml">
            <form string="Device Token">
                <sheet>
                    <group col="4">
                        <field name="name"/>
                        <field name="organization_id"/>
                        <field name="partner_id"/>
                        <field name="platform"/>
                        <field name="device_id"/>
                        <field name="active"/>
                        <field name="last_used"/>
                    </group>
                    <div class="alert alert-warning mt16">
                        Device tokens are stored securely and used for push notifications via Bird.
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
