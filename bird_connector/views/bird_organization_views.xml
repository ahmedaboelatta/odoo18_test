<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bird_organization_tree" model="ir.ui.view">
        <field name="name">bird.organization.tree</field>
        <field name="model">bird.organization</field>
        <field name="arch" type="xml">
            <list string="Organizations">
                <field name="name"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'"/>
                <field name="wallet_balance"/>
                <field name="currency_code"/>
            </list>
        </field>
    </record>

    <record id="view_bird_organization_form" model="ir.ui.view">
        <field name="name">bird.organization.form</field>
        <field name="model">bird.organization</field>
        <field name="arch" type="xml">
            <form string="Organization">
                <header>
                    <button name="action_check_connection" type="object" class="btn btn-primary" string="Check Connection" invisible="state == 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Organization Name..."/></h1>
                    </div>
                    <group>
                        <group string="API Configuration">
                            <field name="api_key" password="True"/>
                            <field name="bird_id"/>
                        </group>
                        <group string="Balance Info">
                            <field name="wallet_balance"/>
                            <field name="currency_code"/>
                            <field name="low_balance_threshold"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Workspaces" name="workspaces">
                            <field name="workspace_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Channels" name="channels">
                            <field name="channel_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Messages" name="messages">
                            <field name="message_ids" readonly="1">
                                <list>
                                    <field name="contact_id"/>
                                    <field name="direction"/>
                                    <field name="status"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bird_organization" model="ir.actions.act_window">
        <field name="name">Organizations</field>
        <field name="res_model">bird.organization</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Bird Organization connection!
            </p>
        </field>
    </record>
</odoo>