<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bird_organization_tree" model="ir.ui.view">
            <field name="name">bird.organization.tree</field>
            <field name="model">bird.organization</field>
            <field name="arch" type="xml">
                <list string="Bird Organizations">
                    <field name="name"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'inactive'"/>
                    <field name="wallet_balance"/>
                    <field name="currency_code"/>
                    <field name="bird_id"/>
                </list>
            </field>
        </record>

        <record id="view_bird_organization_search" model="ir.ui.view">
            <field name="name">bird.organization.search</field>
            <field name="model">bird.organization</field>
            <field name="arch" type="xml">
                <search string="Search Bird Organizations">
                    <field name="name"/>
                    <field name="bird_id"/>
                    <filter string="Active" name="filter_active" domain="[('state','=','active')]"/>
                    <filter string="Inactive" name="filter_inactive" domain="[('state','=','inactive')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_bird_organization_form" model="ir.ui.view">
            <field name="name">bird.organization.form</field>
            <field name="model">bird.organization</field>
            <field name="arch" type="xml">
                <form string="Bird Organization">
                    <header>
                        <button name="action_test_connection"
                                type="object"
                                string="Test Connection"
                                class="btn-primary"
                                confirm="Are you sure you want to test the connection?"/>
                        <button name="action_sync_workspaces_and_channels"
                                type="object"
                                string="Sync Workspaces &amp; Channels"
                                class="btn-secondary"
                                confirm="Sync workspaces and channels from Bird API?"/>
                        <field name="state" widget="statusbar" statusbar_visible="active,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <div>
                                <h1><field name="name" placeholder="Organization Name" required="1"/></h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="bird_id"/>
                                <field name="access_key"/>
                                <field name="workspace_id"/>
                            </group>
                            <group>
                                <field name="wallet_balance"/>
                                <field name="currency_code"/>
                                <field name="low_balance_threshold"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Workspaces">
                                <field name="workspace_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="workspace_id"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Channels" name="channels_page">
                                <field name="channel_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="channel_id"/>
                                        <field name="channel_type"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Templates" name="templates_page">
                                <field name="template_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="bird_template_id"/>
                                        <field name="locale"/>
                                        <field name="status"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
