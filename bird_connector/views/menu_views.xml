<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bird_connector_menu" model="ir.ui.menu">
        <field name="name">Bird Connector</field>
        <field name="sequence">10</field>
    </record>

    <!-- Organizations -->
    <record id="action_bird_organization" model="ir.actions.act_window">
        <field name="name">Organizations</field>
        <field name="res_model">bird.organization</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="bird_connector.view_bird_organization_search"/>
    </record>
    <record id="bird_organization_menu" model="ir.ui.menu">
        <field name="name">Organizations</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">10</field>
        <field name="action" ref="bird_connector.action_bird_organization"/>
    </record>

    <!-- Workspaces -->
    <record id="action_bird_workspace" model="ir.actions.act_window">
        <field name="name">Workspaces</field>
        <field name="res_model">bird.workspace</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="bird_workspace_menu" model="ir.ui.menu">
        <field name="name">Workspaces</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">20</field>
        <field name="action" ref="bird_connector.action_bird_workspace"/>
    </record>

    <!-- Channels -->
    <record id="action_bird_channel" model="ir.actions.act_window">
        <field name="name">Channels</field>
        <field name="res_model">bird.channel</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="bird_channel_menu" model="ir.ui.menu">
        <field name="name">Channels</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">30</field>
        <field name="action" ref="bird_connector.action_bird_channel"/>
    </record>

    <!-- Contacts -->
    <record id="action_bird_contact" model="ir.actions.act_window">
        <field name="name">Contacts</field>
        <field name="res_model">bird.contact</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="bird_contact_menu" model="ir.ui.menu">
        <field name="name">Contacts</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">40</field>
        <field name="action" ref="bird_connector.action_bird_contact"/>
    </record>

    <!-- Conversations -->
    <record id="action_bird_conversation" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">bird.conversation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{ 'search_default_group_by_last_message_at': 1 }</field>
    </record>
    <record id="bird_conversation_menu" model="ir.ui.menu">
        <field name="name">Conversations</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">50</field>
        <field name="action" ref="bird_connector.action_bird_conversation"/>
    </record>

    <!-- Messages -->
    <record id="action_bird_message" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">bird.message</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="bird_message_menu" model="ir.ui.menu">
        <field name="name">Messages</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">60</field>
        <field name="action" ref="bird_connector.action_bird_message"/>
    </record>

    <!-- Templates -->
    <record id="action_bird_template" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">bird.template</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="bird_template_menu" model="ir.ui.menu">
        <field name="name">Templates</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">70</field>
        <field name="action" ref="bird_connector.action_bird_template"/>
    </record>

    <!-- Device Tokens -->
    <record id="action_bird_device_token" model="ir.actions.act_window">
        <field name="name">Device Tokens</field>
        <field name="res_model">bird.device.token</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="bird_device_token_menu" model="ir.ui.menu">
        <field name="name">Device Tokens</field>
        <field name="parent_id" ref="bird_connector_menu"/>
        <field name="sequence">80</field>
        <field name="action" ref="bird_connector.action_bird_device_token"/>
    </record>
</odoo>
