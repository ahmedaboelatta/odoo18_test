<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bird_contact_tree" model="ir.ui.view">
        <field name="name">bird.contact.tree</field>
        <field name="model">bird.contact</field>
        <field name="arch" type="xml">
            <tree string="Contacts">
                <field name="name"/>
                <field name="organization_id"/>
                <field name="contact_id"/>
                <field name="phone_number"/>
                <field name="email"/>
                <field name="channel"/>
            </tree>
        </field>
    </record>
    <record id="view_bird_contact_form" model="ir.ui.view">
        <field name="name">bird.contact.form</field>
        <field name="model">bird.contact</field>
        <field name="arch" type="xml">
            <form string="Contact">
                <sheet>
                    <group col="4">
                        <field name="name"/>
                        <field name="organization_id"/>
                        <field name="partner_id"/>
                        <field name="contact_id"/>
                        <field name="phone_number"/>
                        <field name="email"/>
                        <field name="channel"/>
                        <field name="tags"/>
                    </group>
                    <notebook>
                        <page string="Custom Data" name="custom_data">
                            <field name="custom_data" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
