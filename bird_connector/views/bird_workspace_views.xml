<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_bird_workspace_tree" model="ir.ui.view">
            <field name="name">bird.workspace.tree</field>
            <field name="model">bird.workspace</field>
            <field name="arch" type="xml">
                <list string="Bird Workspaces">
                    <field name="name"/>
                    <field name="workspace_id"/>
                    <field name="organization_id"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'inactive'"/>
                </list>
            </field>
        </record>

        <!-- Search View (Fixed filters by adding 'name') -->
        <record id="view_bird_workspace_search" model="ir.ui.view">
            <field name="name">bird.workspace.search</field>
            <field name="model">bird.workspace</field>
            <field name="arch" type="xml">
                <search string="Search Bird Workspaces">
                    <field name="name"/>
                    <field name="workspace_id"/>
                    <field name="organization_id"/>
                    <filter string="Active" name="filter_active" domain="[('state','=','active')]"/>
                    <filter string="Inactive" name="filter_inactive" domain="[('state','=','inactive')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Organization" name="group_by_organization" context="{'group_by': 'organization_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form View (Fixed statusbar and cleaned One2many fields) -->
        <record id="view_bird_workspace_form" model="ir.ui.view">
            <field name="name">bird.workspace.form</field>
            <field name="model">bird.workspace</field>
            <field name="arch" type="xml">
                <form string="Bird Workspace">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="active,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <div>
                                <h1><field name="name" placeholder="Workspace Name" required="1"/></h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="workspace_id"/>
                                <field name="organization_id"/>
                            </group>
                            <group>
                                <field name="state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Channels" name="channels_page">
                                <field name="channel_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="channel_type"/>
                                        <field name="channel_id"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Templates" name="templates_page">
                                <field name="template_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="template_type"/>
                                        <field name="status" widget="badge" decoration-success="status=='active'" decoration-warning="status=='draft'" decoration-info="status=='pending'"/>
                                        <field name="locale"/>
                                        <field name="version"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>