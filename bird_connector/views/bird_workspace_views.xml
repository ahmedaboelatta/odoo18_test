<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bird_workspace_tree" model="ir.ui.view">
            <field name="name">bird.workspace.tree</field>
            <field name="model">bird.workspace</field>
            <field name="arch" type="xml">
                <list string="Bird Workspaces">
                    <field name="name"/>
                    <field name="workspace_id"/>
                    <field name="organization_id"/>
                    <field name="state" decoration-info="state=='inactive'"/>
                </list>
            </field>
        </record>

        <record id="view_bird_workspace_search" model="ir.ui.view">
            <field name="name">bird.workspace.search</field>
            <field name="model">bird.workspace</field>
            <field name="arch" type="xml">
                <search string="Search Bird Workspaces">
                    <field name="name"/>
                    <field name="workspace_id"/>
                    <field name="organization_id"/>
                    <filter string="Active" context="[('state','=','active')]"/>
                    <filter string="Inactive" context="[('state','=','inactive')]"/>
                </search>
            </field>
        </record>

        <record id="view_bird_workspace_form" model="ir.ui.view">
            <field name="name">bird.workspace.form</field>
            <field name="model">bird.workspace</field>
            <field name="arch" type="xml">
                <form string="Bird Workspace">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <div>
                                <h1><field name="name" placeholder="Workspace Name"/></h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="workspace_id"/>
                                <field name="organization_id"/>
                            </group>
                            <group>
                                <field name="state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Channels">
                                <field name="channel_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="channel_type"/>
                                        <field name="channel_id"/>
                                        <field name="state"/>
                                    </list>
                                    <form>
                                        <group>
                                            <field name="name"/>
                                            <field name="channel_type"/>
                                            <field name="channel_id"/>
                                            <field name="connected_account"/>
                                            <field name="state"/>
                                            <field name="last_activity"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            <page string="Templates">
                                <field name="template_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="template_type"/>
                                        <field name="status" widget="badge" decoration-success="status=='active'" decoration-warning="status=='draft'" decoration-info="status=='pending'"/>
                                        <field name="locale"/>
                                        <field name="version"/>
                                    </list>
                                    <form>
                                        <group>
                                            <field name="name"/>
                                            <field name="template_type"/>
                                            <field name="status"/>
                                            <field name="project_id"/>
                                            <field name="bird_template_id"/>
                                            <field name="version"/>
                                            <field name="locale"/>
                                            <field name="header_text"/>
                                            <field name="footer_text"/>
                                            <field name="body"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
