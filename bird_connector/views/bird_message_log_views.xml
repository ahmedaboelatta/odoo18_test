<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bird_message_log_tree" model="ir.ui.view">
            <field name="name">bird.message.log.tree</field>
            <field name="model">bird.message.log</field>
            <field name="arch" type="xml">
                <tree string="Bird Message Logs">
                    <field name="send_date"/>
                    <field name="receiver_mobile"/>
                    <field name="template_id"/>
                    <field name="project_id"/>
                    <field name="version_id"/>
                    <field name="status" decoration-success="status=='delivered' or status=='read'" decoration-danger="status=='failed'"/>
                    <field name="channel_id"/>
                    <field name="error_message"/>
                </tree>
            </field>
        </record>

        <record id="view_bird_message_log_search" model="ir.ui.view">
            <field name="name">bird.message.log.search</field>
            <field name="model">bird.message.log</field>
            <field name="arch" type="xml">
                <search string="Search Bird Message Logs">
                    <field name="receiver_mobile"/>
                    <field name="template_id"/>
                    <field name="project_id"/>
                    <field name="status"/>
                    <field name="channel_id"/>
                    <filter string="Failed" context="[('status','=','failed')]"/>
                    <filter string="Delivered" context="[('status','=','delivered')]"/>
                </search>
            </field>
        </record>

        <record id="view_bird_message_log_form" model="ir.ui.view">
            <field name="name">bird.message.log.form</field>
            <field name="model">bird.message.log</field>
            <field name="arch" type="xml">
                <form string="Bird Message Log">
                    <header>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="receiver_mobile"/>
                            <div>
                                <h1><field name="receiver_mobile"/></h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="send_date"/>
                                <field name="channel_id"/>
                                <field name="workspace_id"/>
                            </group>
                            <group>
                                <field name="template_id"/>
                                <field name="project_id"/>
                                <field name="version_id"/>
                                <field name="locale"/>
                            </group>
                        </group>
                        <group>
                            <field name="parameters" placeholder="JSON parameters sent with the template"/>
                            <field name="bird_response"/>
                            <field name="error_message"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
