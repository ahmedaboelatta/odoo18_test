<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bird_template_tree" model="ir.ui.view">
        <field name="name">bird.template.tree</field>
        <field name="model">bird.template</field>
        <field name="arch" type="xml">
            <list string="Templates" decoration-info="status == 'draft'" decoration-success="status == 'active'">
                <field name="name"/>
                <field name="organization_id"/>
                <field name="workspace_id"/>
                <field name="template_type"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'active'"/>
                <field name="default_locale"/>
                <field name="bird_template_id"/>
            </list>
        </field>
    </record>
    <record id="view_bird_template_form" model="ir.ui.view">
        <field name="name">bird.template.form</field>
        <field name="model">bird.template</field>
        <field name="arch" type="xml">
            <form string="Template">
                <header>
                    <field name="status" decoration-bf="status=='draft'" decoration-bs="status=='active'"/>
                    <button name="action_sync_to_bird" type="object" class="btn btn-primary" string="Sync to Bird"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template Name"/></h1>
                    </div>
                    <group col="4">
                        <field name="organization_id"/>
                        <field name="workspace_id"/>
                        <field name="template_type"/>
                        <field name="status"/>
                        <field name="bird_template_id"/>
                        <field name="project_id"/>
                        <field name="default_locale"/>
                        <field name="supported_platforms"/>
                        <field name="locales"/>
                        <field name="short_links_enabled"/>
                        <field name="short_links_domain"/>
                        <field name="is_cloneable"/>
                    </group>
                    <notebook>
                        <page string="Platform Info" name="platform_info">
                            <field name="platform_info" nolabel="1" placeholder="JSON platform configuration"/>
                        </page>
                        <page string="Platform Content" name="platform_content">
                            <field name="platform_content" nolabel="1"/>
                        </page>
                        <page string="WhatsApp Preview" name="preview">
                            <div class="row">
                                <div class="col-12 col-md-6">
                                    <field name="header_image_url" string="Header Image URL" placeholder="https://..."/>
                                    <field name="header_video_url" string="Header Video URL" placeholder="https://..."/>
                                    <field name="header_text" string="Header Text" class="form-control"/>
                                </div>
                                <div class="col-12 col-md-6">
                                    <field name="body_text" string="Body Text" class="form-control" nolabel="1" placeholder="Write your message body here. Supports emojis and bold text."/>
                                </div>
                            </div>
                            <div class="row mt16">
                                <div class="col-12 col-md-6">
                                    <field name="footer_text" string="Footer Text" class="form-control" nolabel="1" placeholder="Footer text..."/>
                                </div>
                                <div class="col-12 col-md-6">
                                    <field name="button_text" string="Button Text" placeholder="اطلب الآن" class="form-control"/>
                                    <field name="button_url" string="Button URL" placeholder="https://..." class="form-control mt-2"/>
                                </div>
                            </div>
                            <field name="channel_ids" string="Channels" class="mt16"/>
                        </page>
                        <page string="Variables" name="variables">
                            <field name="variable_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="bird_variable"/>
                                    <field name="odoo_model"/>
                                    <field name="odoo_field"/>
                                    <field name="expression"/>
                                    <field name="example_value"/>
                                    <field name="is_active"/>
                                </list>
                                <form>
                                    <group col="4">
                                        <field name="bird_variable"/>
                                        <field name="odoo_model"/>
                                        <field name="odoo_field"/>
                                        <field name="expression"/>
                                        <field name="example_value"/>
                                        <field name="is_active"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Messages" name="messages">
                            <field name="message_count" string="Total Messages"/>
                            <field name="message_ids">
                                <list decoration-info="direction=='inbound'" decoration-secondary="direction=='outbound'">
                                    <field name="direction"/>
                                    <field name="status"/>
                                    <field name="body" string="Content"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
