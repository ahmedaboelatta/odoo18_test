<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bird_template_tree" model="ir.ui.view">
            <field name="name">bird.template.tree</field>
            <field name="model">bird.template</field>
            <field name="arch" type="xml">
                <list string="Bird Templates">
                    <field name="name"/>
                    <field name="workspace_id"/>
                    <field name="template_type"/>
                    <field name="status" widget="badge" decoration-success="status=='active'" decoration-warning="status=='draft'" decoration-info="status=='pending'"/>
                    <field name="locale"/>
                    <field name="version"/>
                    <field name="project_id"/>
                </list>
            </field>
        </record>

        <record id="view_bird_template_search" model="ir.ui.view">
            <field name="name">bird.template.search</field>
            <field name="model">bird.template</field>
            <field name="arch" type="xml">
                <search string="Search Bird Templates">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="workspace_id"/>
                    <field name="locale"/>
                    <filter string="Active" name="filter_active" domain="[('status','=','active')]"/>
                    <filter string="Draft" name="filter_draft" domain="[('status','=','draft')]"/>
                    <filter string="Pending" name="filter_pending" domain="[('status','=','pending')]"/>
                </search>
            </field>
        </record>

        <record id="view_bird_template_form" model="ir.ui.view">
            <field name="name">bird.template.form</field>
            <field name="model">bird.template</field>
            <field name="arch" type="xml">
                <form string="Bird Template">
                    <header>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <div>
                                <h1><field name="name" placeholder="Template Name"/></h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="workspace_id"/>
                                <field name="template_type"/>
                                <field name="status"/>
                            </group>
                            <group>
                                <field name="project_id"/>
                                <field name="bird_template_id"/>
                                <field name="version"/>
                                <field name="locale"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Platform Info">
                                <group>
                                    <group>
                                        <field name="template_type"/>
                                        <field name="bird_template_id"/>
                                    </group>
                                    <group>
                                        <field name="workspace_id"/>
                                        <field name="organization_id"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Platform Content">
                                <field name="header_text" placeholder="Header text displayed on WhatsApp"/>
                                <field name="body" placeholder="Template body text"/>
                                <field name="footer_text" placeholder="Footer text"/>
                            </page>
                            <page string="Variables">
                                <field name="variables" placeholder='{"employee_name": "John Doe", "company": "Acme"}'/>
                                <div class="alert alert-info" role="alert">
                                    Define dynamic variable mappings in JSON format. These will be injected into the template when sending messages.
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_sync_preview"
                                type="object"
                                string="Sync Preview"
                                class="btn-primary float-end"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
