<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_bird_sync_balance" model="ir.cron">
            <field name="name">Bird: Sync Wallet Balances</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code"><![CDATA[ env['bird.organization']._cron_sync_balances() ]]></field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_bird_sync_templates" model="ir.cron">
            <field name="name">Bird: Update Template Statuses</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code"><![CDATA[ env['bird.template']._cron_sync_template_statuses() ]]></field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_bird_cleanup_messages" model="ir.cron">
            <field name="name">Bird: Cleanup Old Message Logs</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code"><![CDATA[ env['bird.message']._cron_cleanup_old_messages() ]]></field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
