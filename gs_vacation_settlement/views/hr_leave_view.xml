<odoo>
    <record id="inherit_hr_leave_form_view" model="ir.ui.view">
            <field name="name">hr.leave.form2</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='employee_company_id']" position="before">
                    <field name="settlement"/>
                    <field name="settlement_done" invisible="1"/>
                </xpath>
                <xpath expr="//button[@name='action_validate']" position="attributes">
                    <attribute name="invisible">state != 'validate1' or not settlement_done</attribute>
                </xpath>
                <xpath expr="//button[@name='action_validate']" position="after">
                    <button string="Validate" name="action_validate_wizard" invisible="state != 'validate1' or settlement_done" type="object" groups="hr_holidays.group_hr_holidays_user" class="oe_highlight"/>
                </xpath>
            </field>
        </record>
</odoo>