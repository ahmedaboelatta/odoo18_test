<odoo>

    <record id="gs_type_allowances_setting_view_tree" model="ir.ui.view">
        <field name="name">type.allowances.view.tree</field>
        <field name="model">type.allowances</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="gs_type_allowances_setting_view_form" model="ir.ui.view">
        <field name="name">type.allowances.view.form</field>
        <field name="model">type.allowances</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                            <field name="account"/>
                            <field name ="is_type_collected"/>
                            <field name ="is_payroll"/>
                            <field name ="eos_vacation"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="gs_type_allowances_setting_action" model="ir.actions.act_window">
        <field name="name">type.allowances.action</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">type.allowances</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="sub_gs_type_allowances_setting" name="Type allowances &amp;Deduction Setting"  parent="gs_hr_insurance.gs_hr_settings_main_menu" action="gs_type_allowances_setting_action" sequence="24"/>

</odoo>