                                                </td>
                                                <td class="text-right" style="width:50%; border:1px solid #000;">إجمالي المستقطع</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Table 2: Allowances -->
                                <div class="col-6">
                                    <table class="table table-bordered oth_tab" style="border-collapse: collapse;width:100%">
                                        <t t-set="other_allowancess" t-value="0"/>

                                        <thead>
