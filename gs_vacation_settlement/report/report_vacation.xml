<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_vacation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.layout">
                    <t t-set="o" t-value="doc.with_context(lang=lang)"/>
                    <div class="article o_report_layout_standard" t-att-data-oe-model="doc and doc._name"
                         t-att-data-oe-id="doc and doc.id">
                        <t t-call="gs_vacation_settlement.custom_vacation_order_header"/>
                        <style>
                            @font-face {
                            font-family: 'Cairo-Regular';
                            src: local('Cairo-Regular'), local('Cairo-Regular'),
                            url(/gs_invoice_pdf_report/static/src/fonts/cairo/Cairo-Regular.ttf) format('truetype');
                            }

                            .font_cairo {
                            font-family: Cairo-Regular;
                            }

                            .gs_table {
                            border-collapse: collapse;
                            border: 1px solid #000;
                            width: 100%;
                            margin: auto;
                            }

                            .gs_table th, .gs_table td {
                            border: 1px solid #000;
                            padding: 8px;
                            text-align: center;
                            font-size: 12px;
                            }

                            .text-left {
                            text-align: left;
                            direction: ltr;
                            }

                            .text-right {
                            text-align: right;
                            direction: rtl;
                            }

                            .text-center {
                            text-align: center;
                            }

                            .page {
                            font-family: 'Cairo-Regular', sans-serif;
                            margin: 20px;
                            }

                            h2, h3 {
                            color: #3B124C;
                            text-align: center;
                            margin-bottom: 20px;
                            }

                            .oth_tab {

                            }
                            .oth_tab th, .oth_tab td {
                            font-size: 12px;
                            }
                        </style>

                        <div class="page font_cairo" style="margin-top:-10px">
                            <br/>
                            <br/>
                            <table class="gs_table" style="direction: rtl;">
                                <thead>
                                    <tr>
                                        <th style="text-align:center;font-size:20px;color:red;" colspan="6">Vacation
                                            Settlement/ تسوية الإجازة
                                            <br/>
                                            <t t-esc="doc.name"/>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th style="text-align:right; color:blue; margin-right:4px;font-size:18px;" colspan="6">معلومات الموظف
                                        </th>
                                    </tr>
                                    <tr>
                                        <th colspan="2">اسم الموظف:</th>
                                        <th>
                                            <t t-esc="doc.employee_id.name"/>
                                        </th>
                                        <th colspan="2">القسم:</th>
                                        <th>
                                            <t t-esc="doc.employee_id.department_id.name"/>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th colspan="2">الوظيفة:</th>
                                        <th>
                                            <t t-esc="doc.employee_id.job_id.name"/>
                                        </th>
                                        <th colspan="2">الراتب:</th>
                                        <th>
                                            <t t-esc="doc.total_salary"/>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th colspan="2">الرقم الوظيفي:</th>
                                        <th>
                                            <t t-esc="doc.register_num"/>
                                        </th>
                                        <th colspan="2">تاريخ بداية العقد الحالي:</th>
                                        <th>
                                            <t t-esc="doc.current_contract_id.date_start"/>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>أجمالي اجازات الموظف:</th>
                                        <th>
                                            <t t-esc="doc.employee_vacation_allocation"/>
                                        </th>
                                        <th>اجازات الموظف:</th>
                                        <th>
                                            <t t-esc="doc.employee_vacation"/>
                                        </th>
                                        <th>ألمتبقي :</th>
                                        <th>
                                            <t t-esc="int((doc.employee_vacation_allocation or 0) - (doc.employee_vacation or 0))"/>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>الحساب البنكي:</th>
                                        <th colspan="6">
                                            <t t-esc="doc.employee_id.bank_account_id.display_name"/>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>ملاحظات:</th>
                                        <th colspan="6">
                                            <t t-esc="doc.notes"/>
                                        </th>
                                    </tr>
                                </thead>
                            </table>
                            <table class="gs_table" style="direction: rtl;">
