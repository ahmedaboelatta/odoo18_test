                                        </td>
                                        <td>
                                            <t t-esc="doc.leave_end_date"/>
                                        </td>
                                        <td>
                                            <t t-esc="doc.last_work_date"/>
                                        </td>
                                        <td>
                                            <t t-esc="doc.num_of_vacation"/>
                                        </td>
                                        <td>
                                            <t t-esc="doc.financially_accrued_leave"/>
                                        </td>
                                        <!--                                        <td><t t-esc="doc.todays_pay"/></td>-->
                                        <!--                                        <td><t t-esc="doc.amount_due"/></td>-->
                                        <!--                                        <td><t t-esc="doc.tickets_val_company"/></td>-->
                                        <!--                                        <td><t t-esc="doc.tickets_val_company + doc.amount_due"/></td>-->
                                    </tr>
                                </thead>
                            </table>
                            <div style="text-align:right; font-size: 18px; color:blue; border: 1px solid #000;">
