                                                <td class="text-right" style="width:50%; border:1px solid #000;">اجمالي التعويضات</td>
                                            </tr>
                                            <tr>
                                                <td style="width:50%;border:1px solid #000;" class="text-center">
                                                    <t t-set="total_t_allowancess" t-value="doc.amount_due + doc.tickets_val_company + doc.total_payslip_deserved_amount + doc.other_allowance + doc.total_allowances"/>
                                                    <span t-esc="total_t_allowancess"
                                                          t-options='{"widget": "float", "precision": 2}'/>
