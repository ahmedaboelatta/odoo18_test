                                                <td class="text-right" style="width:50%; border:1px solid #000;">اجمالي المستحق</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <table class="table table-bordered" style="direction: ltr;width:100%;">
                                <tr>
                                    <td style="font-size:18px;width:50%;border:1px solid #000;" class="text-center">
                                        <span t-esc="'{:,.2f}'.format(total_t_allowancess - total_t_deduction)"/>
