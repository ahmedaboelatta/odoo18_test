                                            </tr>
                                        </thead>
                                        <tbody>

                                            <tr>
                                                <td style="width:50%;border:1px solid #000;">
                                                    <t t-foreach="docs.detuction_ids" t-as="o">
                                                        <t t-if="o.type_detuction.loan_line and o.type_detuction.type == 'deduction'">
                                                            <t t-set="lone_line" t-value="lone_line + o.detuction"/>
                                                            <span t-esc="lone_line"
                                                                  t-options='{"widget": "float", "precision": 2}'/>
