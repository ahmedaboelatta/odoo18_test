<odoo>
    <record id="view_hr_leave_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.wizard.form</field>
        <field name="model">hr.leave.wizard</field>
        <field name="arch" type="xml">
            <form string="Handle Leave Action">
                <group>
                    <field name="employee_id" readonly="1"/>
                    <field name="type"/>
                    <field name="date"/>
                    <field name="leave_id"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
<!--                    <button string="Cancel" class="btn-secondary" special="cancel"/>-->
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_leave_wizard" model="ir.actions.act_window">
        <field name="name">Handle Leave</field>
        <field name="res_model">hr.leave.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
