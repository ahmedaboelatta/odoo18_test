<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_sync_employees" model="ir.cron">
            <field name="name">Sync Employees</field>
            <field name="model_id" ref="base.model_ir_actions_server"/>
            <field name="state">code</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">12</field>
            <field name="interval_type">hours</field>
            <field name="code">
                <![CDATA[
                env["hr.employee"].sync_with_server()
                ]]>
            </field>
        </record>

        <record id="ir_cron_sync_attendance" model="ir.cron">
            <field name="name">Sync Attendances</field>
            <field name="model_id" ref="base.model_ir_actions_server"/>
            <field name="state">code</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">12</field>
            <field name="interval_type">hours</field>
            <field name="code">
                <![CDATA[
                env["hr.attendance"]._get_from_server()
                ]]>
            </field>
        </record>

        <record id="ir_cron_close_attendance" model="ir.cron">
            <field name="name">Close Attendances</field>
            <field name="model_id" ref="base.model_ir_actions_server"/>
            <field name="state">code</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">12</field>
            <field name="interval_type">hours</field>
            <field name="code">
                <![CDATA[
                env["hr.attendance"]._cron_close_overdue_attendance()
                ]]>
            </field>
        </record>
    </data>
</odoo>
