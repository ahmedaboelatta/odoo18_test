<odoo>
    <data>
        <record id="view_employee_form_inherit_zkteco" model="ir.ui.view">
            <field name="name">hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='identification_group']" position="inside">
                    <field name="zk_emp_code" string="ZKTeco Emp. Code"/>
                    <field name="zk_emp_id" string="ZKTeco Emp. ID" readonly="1" />
                </xpath>
            </field>
        </record>
        
    </data>
</odoo>
